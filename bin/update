#!/bin/bash
#
# Update dotfiles and tools

set -e

# Colors
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

step()    { echo ""; echo -e "${BLUE}➜${NC} $1"; }
success() { echo -e "${GREEN}✓${NC} $1"; }
warn()    { echo -e "${YELLOW}⚠${NC} $1"; }

echo ""
step "Updating dotfiles"
echo ""

# Update dotfiles repo
step "Pulling latest changes"
git -C ~/.dotfiles pull origin main
success "Dotfiles updated"

# Update Homebrew and packages
step "Updating Homebrew packages"
brew update
brew upgrade
brew bundle --file=~/.dotfiles/config/Brewfile
brew cleanup
success "Homebrew packages updated"

# Update Oh My Zsh
step "Updating Oh My Zsh"
if [ -d ~/.oh-my-zsh ]; then
    env ZSH=~/.oh-my-zsh zsh ~/.oh-my-zsh/tools/upgrade.sh || warn "Oh My Zsh update failed"
fi
success "Oh My Zsh updated"

# Update manually-cloned zsh plugins
step "Updating zsh plugins"
for plugin in ~/.dotfiles/zsh/plugins/*/; do
    [ -d "$plugin/.git" ] && git -C "$plugin" pull --ff-only || warn "Failed to update $(basename "$plugin")"
done
success "Zsh plugins updated"

# Update global npm packages
step "Updating global npm packages"
if command -v fnm &>/dev/null; then
    eval "$(fnm env --use-on-cd)"
    fnm use lts-latest || warn "fnm use failed"
    npm update -g || warn "npm update failed"
else
    warn "fnm not found — skipping global npm packages"
fi
success "npm packages updated"

# Done
echo ""
success "Update complete!"
echo ""
warn "Restart your terminal or run: exec zsh"
echo ""
